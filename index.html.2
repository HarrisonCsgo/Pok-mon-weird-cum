<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>Pixel Monster RPG Ultimate</title>

<style>

/* =========================
   GLOBAL
========================= */

*{
  box-sizing:border-box;
}

body{
  margin:0;
  overflow:hidden;

  height:100vh;

  display:flex;
  justify-content:center;
  align-items:center;

  font-family:monospace;

  background:
    radial-gradient(circle at top,#222,#000);
}

/* =========================
   GAME WINDOW
========================= */

#game{
  width:800px;
  height:576px;

  position:relative;
  overflow:hidden;

  border:6px solid white;

  image-rendering:pixelated;

  background:#6dbf5d;

  box-shadow:
    0 0 50px #00ff99,
    inset 0 0 20px rgba(255,255,255,0.2);
}

/* CRT SCANLINES */

#game::after{
  content:"";

  position:absolute;
  inset:0;

  pointer-events:none;

  background:
    repeating-linear-gradient(
      to bottom,
      rgba(255,255,255,0.03),
      rgba(255,255,255,0.03) 2px,
      transparent 2px,
      transparent 4px
    );
}

/* =========================
   TILES
========================= */

.tile{
  width:32px;
  height:32px;

  position:absolute;
}

/* GRASS */

.grass{
  background:
    linear-gradient(
      45deg,
      #5fae4f,
      #6dbf5d
    );

  animation:grassMove 1s infinite alternate;
}

@keyframes grassMove{
  from{
    filter:brightness(1);
  }
  to{
    filter:brightness(1.08);
  }
}

/* PATH */

.path{
  background:
    repeating-linear-gradient(
      45deg,
      #b79d63,
      #b79d63 6px,
      #cbb27a 6px,
      #cbb27a 12px
    );
}

/* TREE */

.tree{
  background:
    radial-gradient(circle,#2ecc71,#145a32);

  border:2px solid #0b3d0b;
}

/* WATER */

.water{
  background:
    repeating-linear-gradient(
      45deg,
      #3498db,
      #3498db 6px,
      #5dade2 6px,
      #5dade2 12px
    );

  animation:waterFlow 1s linear infinite;
}

@keyframes waterFlow{
  from{
    background-position:0 0;
  }
  to{
    background-position:32px 0;
  }
}

/* =========================
   PLAYER
========================= */

#player{
  width:28px;
  height:28px;

  position:absolute;

  z-index:50;

  transition:0.08s linear;

  border-radius:4px;

  image-rendering:pixelated;

  background:
    linear-gradient(#222 0 0) 10px 2px/8px 6px no-repeat,
    linear-gradient(#ffe0bd 0 0) 8px 8px/12px 10px no-repeat,
    linear-gradient(#3498db 0 0) 6px 18px/16px 8px no-repeat;

  filter:
    drop-shadow(0 0 6px white);
}

/* =========================
   HUD
========================= */

#hud{
  position:absolute;

  top:10px;
  left:10px;

  z-index:100;

  color:white;

  background:rgba(0,0,0,0.6);

  padding:12px;

  border:2px solid white;

  min-width:200px;
}

#controls{
  position:absolute;

  right:10px;
  bottom:10px;

  z-index:100;

  color:white;

  background:rgba(0,0,0,0.6);

  padding:12px;

  border:2px solid white;
}

/* =========================
   BATTLE SCREEN
========================= */

#battleScreen{
  position:absolute;
  inset:0;

  display:none;

  z-index:200;

  flex-direction:column;
  justify-content:center;
  align-items:center;

  background:
    radial-gradient(circle,#2c003e,#000);

  color:white;
}

/* ENEMY */

.enemy{
  width:140px;
  height:140px;

  display:flex;
  justify-content:center;
  align-items:center;

  font-size:90px;

  border:4px solid white;

  border-radius:12px;

  background:#8e44ad;

  box-shadow:
    0 0 30px #ff00ff;

  animation:float 1s infinite alternate;
}

@keyframes float{
  from{
    transform:translateY(0px);
  }
  to{
    transform:translateY(-10px);
  }
}

/* HP BAR */

.hpbar{
  width:240px;
  height:24px;

  border:3px solid white;

  margin-top:15px;

  background:#333;
}

.hp{
  height:100%;
  width:100%;

  background:
    linear-gradient(
      to right,
      lime,
      #00ff88
    );

  transition:0.3s;
}

/* TEXTBOX */

#textbox{
  width:80%;

  margin-top:20px;

  background:white;

  color:black;

  padding:15px;

  border:4px solid black;

  text-align:center;

  min-height:70px;
}

/* =========================
   BUTTONS
========================= */

button{
  margin:10px;
  padding:14px 22px;

  border:none;

  font-size:18px;

  font-family:monospace;

  cursor:pointer;

  background:#f1c40f;

  transition:0.15s;

  box-shadow:0 4px #b7950b;
}

button:hover{
  transform:translateY(-2px);
  background:#ffdf40;
}

button:active{
  transform:translateY(3px);
  box-shadow:none;
}

/* =========================
   SCREEN SHAKE
========================= */

.shake{
  animation:shake 0.2s;
}

@keyframes shake{
  0%{transform:translateX(0)}
  25%{transform:translateX(5px)}
  50%{transform:translateX(-5px)}
  75%{transform:translateX(5px)}
  100%{transform:translateX(0)}
}

/* =========================
   MOBILE CONTROLS
========================= */

#mobileControls{
  position:absolute;

  bottom:10px;
  left:50%;

  transform:translateX(-50%);

  z-index:300;

  display:none;

  gap:10px;

  flex-wrap:wrap;

  width:220px;

  justify-content:center;
}

.mobileBtn{
  width:60px;
  height:60px;

  border-radius:12px;

  font-size:24px;
}

@media(max-width:900px){

  #mobileControls{
    display:flex;
  }

  #game{
    transform:scale(0.9);
  }
}

</style>
</head>
<body>

<div id="game">

  <!-- HUD -->

  <div id="hud">

    <b>PIXEL MONSTER RPG ULTIMATE</b>

    <br><br>

    HP:
    <span id="hpText">100</span>

    <br>

    LVL:
    <span id="levelText">1</span>

    <br>

    XP:
    <span id="xpText">0</span>

    <br>

    GOLD:
    <span id="goldText">0</span>

    <br><br>

    Explore and battle!

  </div>

  <!-- CONTROLS -->

  <div id="controls">
    Arrow Keys = Move
  </div>

  <!-- PLAYER -->

  <div id="player"></div>

  <!-- BATTLE -->

  <div id="battleScreen">

    <div class="enemy" id="enemySprite">
      👾
    </div>

    <h1 id="enemyName">
      WILD SLIME
    </h1>

    <div class="hpbar">
      <div class="hp" id="enemyHp"></div>
    </div>

    <div>

      <!-- OLD BUTTONS -->
      <button onclick="attack()">
        ATTACK
      </button>

      <button onclick="heal()">
        HEAL
      </button>

      <button onclick="runAway()">
        RUN
      </button>

      <!-- NEW BUTTON -->
      <button onclick="specialAttack()">
        SPECIAL
      </button>

    </div>

    <div id="textbox">
      A wild slime appeared!
    </div>

  </div>

  <!-- MOBILE -->

  <div id="mobileControls">

    <button class="mobileBtn" onclick="move('up')">
      ↑
    </button>

    <button class="mobileBtn" onclick="move('left')">
      ←
    </button>

    <button class="mobileBtn" onclick="move('down')">
      ↓
    </button>

    <button class="mobileBtn" onclick="move('right')">
      →
    </button>

  </div>

</div>

<script>

/* =========================
   ELEMENTS
========================= */

const game =
  document.getElementById("game");

const player =
  document.getElementById("player");

const battleScreen =
  document.getElementById("battleScreen");

const textbox =
  document.getElementById("textbox");

const enemyHpBar =
  document.getElementById("enemyHp");

const hpText =
  document.getElementById("hpText");

const levelText =
  document.getElementById("levelText");

const xpText =
  document.getElementById("xpText");

const goldText =
  document.getElementById("goldText");

const enemySprite =
  document.getElementById("enemySprite");

const enemyName =
  document.getElementById("enemyName");

/* =========================
   MAP SETTINGS
========================= */

const mapWidth = 25;
const mapHeight = 18;
const tileSize = 32;

/* =========================
   PLAYER STATS
========================= */

let playerX = 12;
let playerY = 9;

let playerHp = 100;

let level = 1;
let xp = 0;
let gold = 0;

/* =========================
   BATTLE
========================= */

let enemyHp = 100;
let inBattle = false;

/* =========================
   ENEMIES
========================= */

const enemies = [

  {
    name:"SLIME",
    emoji:"👾",
    hp:100
  },

  {
    name:"GHOST",
    emoji:"👻",
    hp:120
  },

  {
    name:"DEMON",
    emoji:"😈",
    hp:150
  },

  {
    name:"DRAGON",
    emoji:"🐉",
    hp:180
  }

];

/* =========================
   MAP
========================= */

const map = [];

function createMap(){

  for(let y=0;y<mapHeight;y++){

    for(let x=0;x<mapWidth;x++){

      const tile =
        document.createElement("div");

      tile.classList.add("tile");

      let type = "grass";

      /* ORIGINAL BORDER TREES */

      if(
        x === 0 ||
        y === 0 ||
        x === mapWidth-1 ||
        y === mapHeight-1
      ){
        type = "tree";
      }

      /* ORIGINAL WATER */

      if(Math.random() < 0.05){
        type = "water";
      }

      /* ORIGINAL TREES */

      if(Math.random() < 0.08){
        type = "tree";
      }

      /* ORIGINAL PATH */

      if(y === 8 || y === 9){
        type = "path";
      }

      tile.classList.add(type);

      tile.style.left =
        x * tileSize + "px";

      tile.style.top =
        y * tileSize + "px";

      game.appendChild(tile);

      map.push({
        x,
        y,
        type
      });
    }
  }
}

createMap();

/* =========================
   PLAYER
========================= */

function updatePlayer(){

  player.style.left =
    playerX * tileSize + 2 + "px";

  player.style.top =
    playerY * tileSize + 2 + "px";
}

function updateStats(){

  hpText.innerText = playerHp;
  levelText.innerText = level;
  xpText.innerText = xp;
  goldText.innerText = gold;
}

updatePlayer();
updateStats();

/* =========================
   MOVEMENT
========================= */

document.addEventListener("keydown", e => {

  if(inBattle) return;

  if(e.key === "ArrowRight") move("right");
  if(e.key === "ArrowLeft") move("left");
  if(e.key === "ArrowUp") move("up");
  if(e.key === "ArrowDown") move("down");

});

function move(dir){

  if(inBattle) return;

  let newX = playerX;
  let newY = playerY;

  if(dir === "right") newX++;
  if(dir === "left") newX--;
  if(dir === "up") newY--;
  if(dir === "down") newY++;

  const tile = map.find(
    t => t.x === newX && t.y === newY
  );

  if(!tile) return;

  /* ORIGINAL COLLISION */

  if(
    tile.type === "tree" ||
    tile.type === "water"
  ){
    return;
  }

  playerX = newX;
  playerY = newY;

  updatePlayer();

  /* ORIGINAL BATTLE CHANCE */

  if(tile.type === "grass"){

    if(Math.random() < 0.12){

      startBattle();

    }

  }
}

/* =========================
   BATTLE START
========================= */

let currentEnemy;

function startBattle(){

  inBattle = true;

  currentEnemy =
    enemies[
      Math.floor(
        Math.random()*enemies.length
      )
    ];

  enemyHp = currentEnemy.hp;

  enemyName.innerText =
    "WILD " + currentEnemy.name;

  enemySprite.innerText =
    currentEnemy.emoji;

  enemyHpBar.style.width = "100%";

  textbox.innerText =
    "A wild " +
    currentEnemy.name +
    " appeared!";

  battleScreen.style.display = "flex";
}

/* =========================
   ORIGINAL ATTACK
========================= */

function attack(){

  const damage =
    Math.floor(Math.random()*20)+10;

  let finalDamage = damage;

  /* NEW CRITS */

  const crit =
    Math.random() < 0.15;

  if(crit){
    finalDamage *= 2;
  }

  enemyHp -= finalDamage;

  if(enemyHp < 0){
    enemyHp = 0;
  }

  enemyHpBar.style.width =
    enemyHp + "%";

  battleScreen.classList.add("shake");

  setTimeout(() => {
    battleScreen.classList.remove("shake");
  },200);

  textbox.innerText =
    crit
    ? "CRITICAL HIT! " +
      finalDamage +
      " damage!"
    : "You dealt " +
      finalDamage +
      " damage!";

  if(enemyHp <= 0){

    victory();

    return;
  }

  setTimeout(enemyAttack,700);
}

/* =========================
   SPECIAL ATTACK
========================= */

function specialAttack(){

  let damage =
    Math.floor(Math.random()*35)+25;

  enemyHp -= damage;

  if(enemyHp < 0){
    enemyHp = 0;
  }

  enemyHpBar.style.width =
    enemyHp + "%";

  textbox.innerText =
    "SPECIAL ATTACK! " +
    damage +
    " damage!";

  battleScreen.classList.add("shake");

  setTimeout(() => {
    battleScreen.classList.remove("shake");
  },200);

  if(enemyHp <= 0){

    victory();

    return;
  }

  setTimeout(enemyAttack,700);
}

/* =========================
   ORIGINAL ENEMY ATTACK
========================= */

function enemyAttack(){

  const damage =
    Math.floor(Math.random()*12)+4;

  playerHp -= damage;

  if(playerHp < 0){
    playerHp = 0;
  }

  updateStats();

  textbox.innerText =
    currentEnemy.name +
    " hit you for " +
    damage + "!";

  if(playerHp <= 0){

    textbox.innerText =
      "You fainted! Refresh to retry.";

  }
}

/* =========================
   ORIGINAL HEAL
========================= */

function heal(){

  playerHp += 20;

  if(playerHp > 100){
    playerHp = 100;
  }

  updateStats();

  textbox.innerText =
    "You healed!";

  setTimeout(enemyAttack,700);
}

/* =========================
   ORIGINAL RUN
========================= */

function runAway(){

  textbox.innerText =
    "You escaped!";

  setTimeout(() => {

    battleScreen.style.display = "none";

    inBattle = false;

  },800);
}

/* =========================
   VICTORY
========================= */

function victory(){

  const gainedXp =
    Math.floor(Math.random()*25)+15;

  const gainedGold =
    Math.floor(Math.random()*20)+5;

  xp += gainedXp;
  gold += gainedGold;

  /* ORIGINAL LEVEL SYSTEM */

  if(xp >= level * 50){

    xp = 0;

    level++;

    playerHp = 100;

    textbox.innerText =
      "LEVEL UP!";

  }else{

    textbox.innerText =
      currentEnemy.name +
      " defeated! +" +
      gainedXp +
      " XP +" +
      gainedGold +
      " GOLD";

  }

  updateStats();

  setTimeout(() => {

    battleScreen.style.display = "none";

    inBattle = false;

  },1500);
}

</script>

</body>
</html>
